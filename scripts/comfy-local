#!/usr/bin/env bash
set -euo pipefail

repo_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
config_file="${COMFY_LOCAL_CONFIG:-$repo_dir/.env.local}"
env_source="none"
runtime_env_source="none"

load_local_env() {
  if [[ -n "${COMFY_LOCAL_CONFIG:-}" ]]; then
    if [[ -f "$config_file" ]]; then
      set -a
      # shellcheck source=/dev/null
      source "$config_file"
      set +a
      env_source="$config_file"
    else
      env_source="missing COMFY_LOCAL_CONFIG: $config_file"
    fi
    return
  fi

  if command -v direnv >/dev/null 2>&1 && [[ -f "$repo_dir/.envrc" ]]; then
    local direnv_env
    if direnv_env="$(cd "$repo_dir" && direnv export bash 2>/dev/null)" && [[ -n "$direnv_env" ]]; then
      eval "$direnv_env"
      env_source="direnv: $repo_dir/.envrc"
      return
    fi
  fi

  local fallback
  for fallback in "$repo_dir/.env.local" "$repo_dir/.envrc.local"; do
    if [[ -f "$fallback" ]]; then
      set -a
      # shellcheck source=/dev/null
      source "$fallback"
      set +a
      if [[ "$env_source" == "none" ]]; then
        env_source="$fallback"
      else
        env_source="$env_source, $fallback"
      fi
    fi
  done
}

load_local_env

# Up-front declarative settings loader (T006 / T030 for 004)
# Looks for a local ignored settings file with key=value pairs.
# This allows configuring patching policy, launch behavior (tmux), model enrichment,
# and protection reminders without hard-coding.
load_comfygo_settings() {
  local settings_file="${COMFYGO_SETTINGS:-$repo_dir/.comfygo-settings}"
  if [[ -f "$settings_file" ]]; then
    set -a
    # shellcheck source=/dev/null
    source "$settings_file"
    set +a
    echo "Loaded comfygo settings from $settings_file (env_source was: $env_source)"
    env_source="$env_source, $settings_file"
  else
    # Default safe settings if no file
    COMFYGO_LAUNCH_TMUX_NAME="${COMFYGO_LAUNCH_TMUX_NAME:-comfyui}"
    COMFYGO_PATCH_POLICY="${COMFYGO_PATCH_POLICY:-strict}"
  fi
}

load_comfygo_settings

usage() {
  cat <<'EOF'
Usage:
  scripts/comfy-local <command> [args...]

Commands:
  go                 Apply local integration where possible, sync, then launch.
  doctor             Guided readiness: 16 GCD scenarios, action inventory, recommended-next.
                     Options: --models-dir PATH, --apply <action-id>, --gc-target NAME,
                     --yes, --keep-evidence, --smoke-repatch, --help
  status             Show configured paths and patch state.
  models -f FILTER   Show installed model files and folder-category visibility.
  models enrich <source>  Enrich HF git-clone/loose file (Civitai if COMFYGO_ENRICH_CIVITAI + token).
  models reconcile -f FILTER [--apply]
                     Self-identify full model folders and create compatibility views.
  sync               Sync vendored nodes into ComfyUI and apply ComfyUI patches.
  start              Sync, then launch ComfyUI. Defaults to localhost:8188.
  restart            Stop comfy-cli background ComfyUI, then start it again.
  update             Run comfy update, then resync vendored nodes.
  install            Run comfy install, then resync vendored nodes.
  patch-cli          Apply comfy-cli patches to COMFY_CLI_DIR.
  patch-comfyui      Apply ComfyUI core patches to COMFYUI_DIR.
  refresh-upstreams  Refresh vendored node copies from UPSTREAMS.tsv.
  runtime-envrc      Write a machine-local direnv file for the ComfyUI runtime root.
  tmux-send "command"  Send command to the tmux target (for control from shell).

Configuration:
  Preferred: use direnv with .envrc.local next to this script's parent repo.
  Fallback: use .env.local, or set COMFY_LOCAL_CONFIG to another file.

    COMFYUI_DIR=/path/to/ComfyUI
    COMFY_CLI_DIR=/path/to/comfy-cli

Up-front settings (004 feature, via .comfygo-settings or COMFYGO_SETTINGS):
  COMFYGO_LAUNCH_TMUX_NAME=comfyui          # tmux window/pane name
  COMFYGO_PATCH_POLICY=strict               # strict | lenient
  COMFYGO_ENRICH_CIVITAI=1                  # enable Civitai lookup
  COMFYGO_PROTECTION_REMIND=1               # remind about branch protection

Example .comfygo-settings (gitignored):
  COMFYGO_LAUNCH_TMUX_NAME=my-comfy
  COMFYGO_PATCH_POLICY=strict

EOF
}

require_comfyui_dir() {
  if [[ -z "${COMFYUI_DIR:-}" ]]; then
    echo "COMFYUI_DIR is required. Add it to .envrc.local, .env.local, or export it." >&2
    exit 2
  fi
}

require_comfy_cli_dir() {
  if [[ -z "${COMFY_CLI_DIR:-}" ]]; then
    echo "COMFY_CLI_DIR is required. Add it to .envrc.local, .env.local, or export it." >&2
    exit 2
  fi
}

require_uv() {
  if ! command -v uv >/dev/null 2>&1; then
    echo "uv is required for this repo. Install uv first, then rerun this command." >&2
    echo "See: https://docs.astral.sh/uv/getting-started/installation/" >&2
    exit 2
  fi
}

patch_state() {
  local target_dir="$1"
  local patch="$2"

  if [[ ! -d "$target_dir/.git" ]]; then
    echo "not a git checkout"
  elif git -C "$target_dir" apply --reverse --check "$patch" >/dev/null 2>&1; then
    echo "applied"
  elif git -C "$target_dir" apply --check "$patch" >/dev/null 2>&1; then
    echo "not applied"
  else
    echo "does not apply cleanly"
  fi
}

# T010 / T081: Re-patch / drift detection using manifests (for US1)
# Reads structured manifest.md (## Patched Files, ## Historical Names, ## Rationale).
# Uses Historical Names for matching. On mismatch prints EXACT Error and Exit Contract message.
# Returns / prints "not applied" for decision logic. Non-destructive.
patch_drift_check() {
  local target_dir="$1"
  local patch_dir="$2"  # e.g. comfyui-patches or comfy-cli-patches
  local manifest="$patch_dir/manifest.md"

  if [[ ! -f "$manifest" ]]; then
    echo "no manifest in $patch_dir"
    return
  fi

  echo "Manifest in $patch_dir:"

  # Parse ## Historical Names section (preferred for re-apply matching per FR-004/005, Key Entities, Error Contracts)
  local hist_names=()
  local in_historical=0
  while IFS= read -r line; do
    if [[ "$line" =~ ^##[[:space:]]*Historical[[:space:]]*Names ]]; then
      in_historical=1
      continue
    fi
    if [[ "$line" =~ ^##[[:space:]] ]]; then
      in_historical=0
    fi
    if [[ $in_historical -eq 1 && "$line" =~ ^-[[:space:]]*(.+)$ ]]; then
      local name="${BASH_REMATCH[1]}"
      name=$(echo "$name" | xargs)  # trim
      if [[ -n "$name" ]]; then
        hist_names+=("$name")
      fi
    fi
  done < "$manifest"

  if [[ ${#hist_names[@]} -eq 0 ]]; then
    # Fallback to simple .patch lines if no Historical Names section (backward compat)
    grep -E '\.patch' "$manifest" | while read -r line; do
      patch_file=$(echo "$line" | grep -oE '[^ ]+\.patch' | head -1)
      if [[ -n "$patch_file" && -f "$patch_dir/$patch_file" ]]; then
        state=$(patch_state "$target_dir" "$patch_dir/$patch_file")
        echo "  $patch_file: $state"
      fi
    done
    return
  fi

  # Check each historical name (the .patch filename is typically the historical name)
  for hist in "${hist_names[@]}"; do
    local patch_file="$hist"
    if [[ -f "$patch_dir/$patch_file" ]]; then
      local state
      state=$(patch_state "$target_dir" "$patch_dir/$patch_file")
      echo "  $patch_file (historical: $hist): $state"
      if [[ "$state" == "not applied" ]]; then
        # Emit EXACT message per Error and Exit Contracts (FR-005)
        echo "  ACTION REQUIRED (exact per contract): historical name/path from manifest: $hist ; current file: $patch_dir/$patch_file ; edit $patch_dir/manifest.md and the corresponding .patch file in this repo, then re-apply"
      fi
    else
      echo "  $hist (listed in manifest but patch file missing in $patch_dir)"
    fi
  done
}

expected_node_status() {
  local source_root="$repo_dir/custom_nodes"
  local target_root="$COMFYUI_DIR/custom_nodes"
  local missing=0
  local total=0
  local source
  local name

  if [[ ! -d "$source_root" ]]; then
    echo "Expected nodes: missing source directory $source_root"
    return 1
  fi

  for source in "$source_root"/*; do
    [[ -e "$source" ]] || continue
    total=$((total + 1))
    name="$(basename "$source")"
    if [[ ! -e "$target_root/$name" ]]; then
      echo "Missing expected node: $name"
      missing=$((missing + 1))
    fi
  done

  if (( missing == 0 )); then
    echo "Expected nodes: $total present"
    return 0
  fi

  echo "Expected nodes: $missing missing out of $total"
  return 1
}

collect_comfyui_nvidia_lib_dirs() {
  local old_nullglob
  local nvidia_root
  local lib_dir
  local -A seen=()

  old_nullglob="$(shopt -p nullglob || true)"
  shopt -s nullglob
  for nvidia_root in "$COMFYUI_DIR"/.venv/lib/python*/site-packages/nvidia; do
    for lib_dir in \
      "$nvidia_root"/cu[0-9]*/lib \
      "$nvidia_root"/cublas/lib \
      "$nvidia_root"/cudnn/lib \
      "$nvidia_root"/cusparselt/lib \
      "$nvidia_root"/nccl/lib \
      "$nvidia_root"/nvshmem/lib; do
      if [[ -d "$lib_dir" && -z "${seen[$lib_dir]+x}" ]]; then
        seen[$lib_dir]=1
        printf '%s\n' "$lib_dir"
      fi
    done
  done
  eval "$old_nullglob"
}

prepare_comfyui_runtime_env() {
  local lib_dirs=()
  local lib_dir
  local joined

  require_comfyui_dir

  while IFS= read -r lib_dir; do
    lib_dirs+=("$lib_dir")
  done < <(collect_comfyui_nvidia_lib_dirs)

  if (( ${#lib_dirs[@]} == 0 )); then
    return
  fi

  printf -v joined '%s:' "${lib_dirs[@]}"
  joined="${joined%:}"
  export LD_LIBRARY_PATH="$joined${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
}

comfy_runtime_root() {
  if [[ -n "${COMFY_RUNTIME_ROOT:-}" ]]; then
    printf '%s\n' "$COMFY_RUNTIME_ROOT"
    return
  fi

  require_comfyui_dir
  printf '%s\n' "$(dirname "$COMFYUI_DIR")"
}

runtime_envrc_status() {
  local root

  root="$(comfy_runtime_root)"
  if [[ -f "$root/.envrc" ]]; then
    echo "Runtime direnv: present ($root/.envrc)"
  else
    echo "Runtime direnv: missing ($root/.envrc)"
  fi
}

load_runtime_direnv_env() {
  local root
  local direnv_env
  local configured_comfyui_dir="${COMFYUI_DIR:-}"
  local configured_comfy_cli_dir="${COMFY_CLI_DIR:-}"

  root="$(comfy_runtime_root)"
  if [[ ! -f "$root/.envrc" ]]; then
    runtime_env_source="missing: $root/.envrc"
    return
  fi

  if ! command -v direnv >/dev/null 2>&1; then
    runtime_env_source="direnv missing for $root/.envrc"
    return
  fi

  if direnv_env="$(cd "$root" && direnv export bash 2>/dev/null)" && [[ -n "$direnv_env" ]]; then
    eval "$direnv_env"
    if [[ -n "$configured_comfyui_dir" ]]; then
      export COMFYUI_DIR="$configured_comfyui_dir"
    fi
    if [[ -n "$configured_comfy_cli_dir" ]]; then
      export COMFY_CLI_DIR="$configured_comfy_cli_dir"
    fi
    runtime_env_source="direnv: $root/.envrc"
  else
    runtime_env_source="not loaded: $root/.envrc"
  fi
}

write_runtime_envrc() {
  local root
  local envrc
  local source_file

  root="$(comfy_runtime_root)"
  envrc="$root/.envrc"

  mkdir -p "$root"
  {
    echo "# shellcheck shell=bash"
    echo "# Generated by my-comfyui-nodes. Machine-local; do not commit."
    for source_file in \
      "$HOME/Apps/.envrc.local" \
      "$repo_dir/.envrc.local" \
      "$repo_dir/.env.local"; do
      printf 'source_env_if_exists %q\n' "$source_file"
    done
  } > "$envrc"

  echo "Wrote $envrc"
  echo "Run: cd $root && direnv allow"
}

token_env_status() {
  local name
  local line="Runtime token env:"
  local status=()

  for name in CIVITAI_API_TOKEN CIVITAI_TOKEN HF_TOKEN; do
    if [[ -n "${!name:-}" ]]; then
      status+=("$name=set")
    else
      status+=("$name=not set")
    fi
  done

  for name in "${status[@]}"; do
    line="$line ${name},"
  done
  echo "${line%,}"
}

models_root() {
  local root

  require_comfyui_dir

  if [[ -n "${COMFY_MODELS_DIR:-}" ]]; then
    root="$COMFY_MODELS_DIR"
  elif [[ -e "$COMFYUI_DIR/models" ]]; then
    root="$COMFYUI_DIR/models"
  else
    root="$(dirname "$COMFYUI_DIR")/models"
  fi

  if command -v realpath >/dev/null 2>&1; then
    realpath -m "$root"
  else
    printf '%s\n' "$root"
  fi
}

find_model_payloads() {
  local path="$1"

  find -L "$path" -path '*/.git' -prune -o -type f \( \
    -name '*.safetensors' -o \
    -name '*.gguf' -o \
    -name '*.ckpt' -o \
    -name '*.pt' -o \
    -name '*.pth' -o \
    -name '*.bin' \
  \) -print 2>/dev/null
}

count_model_payloads() {
  local path="$1"

  find_model_payloads "$path" | wc -l | tr -d ' '
}

is_reserved_model_dir() {
  case "$(basename "$1")" in
    .comfygo_views|audio_encoders|background_removal|checkpoints|clip|clip_vision|configs|controlnet|detection|diffusion_models|embeddings|frame_interpolation|geometry_estimation|gligen|hypernetworks|latent_upscale_models|loras|model_patches|optical_flow|photomaker|style_models|text_encoders|ultralytics|unet|upscale_models|vae|vae_approx|yolo)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

is_model_package() {
  local package="$1"

  [[ -f "$package/comfygo-model.json" || -f "$package/model_index.json" ]]
}

print_model_packages() {
  local root="$1"
  local base
  local package

  for base in "$root/library" "$root/diffusers"; do
    [[ -d "$base" ]] || continue
    for package in "$base"/*; do
      [[ -d "$package" ]] || continue
      if is_model_package "$package"; then
        printf '%s\n' "$package"
      fi
    done
  done

  for package in "$root"/*; do
    [[ -d "$package" ]] || continue
    case "$(basename "$package")" in
      .*|library|diffusers)
        continue
        ;;
    esac
    if is_reserved_model_dir "$package"; then
      continue
    fi
    if is_model_package "$package"; then
      printf '%s\n' "$package"
    fi
  done
}

describe_model_package() {
  local root="$1"
  local dir="$2"
  local name
  local label
  local transformer_dir="$dir/transformer"
  local text_encoder_dir="$dir/text_encoder"
  local vae_dir="$dir/vae"
  local diffusion_model_target
  local legacy_diffusion_model_target
  local transformer_count

  name="$(basename "$dir")"
  label="${dir#$root/}"
  diffusion_model_target="$root/.comfygo_views/diffusion_models/$name/transformer"
  legacy_diffusion_model_target="$root/diffusion_models/$name/transformer"

  [[ -d "$dir" ]] || return 0

  echo "  $label"
  if [[ -f "$dir/comfygo-model.json" ]]; then
    echo "    descriptor: yes (comfygo-model.json present)"
  fi
  if [[ -f "$dir/model_index.json" ]]; then
    echo "    full diffusers folder: yes (model_index.json present)"
  elif [[ ! -f "$dir/comfygo-model.json" ]]; then
    echo "    full diffusers folder: no model_index.json found"
  fi

  if [[ -d "$transformer_dir" ]]; then
    transformer_count="$(count_model_payloads "$transformer_dir")"
    echo "    transformer payloads: $transformer_count"
    if [[ -e "$diffusion_model_target" ]]; then
      echo "    Load Diffusion Model visibility: yes (.comfygo_views/diffusion_models/$name/transformer)"
    elif [[ -e "$legacy_diffusion_model_target" ]]; then
      echo "    Load Diffusion Model visibility: yes (diffusion_models/$name/transformer)"
    else
      echo "    Load Diffusion Model visibility: missing (.comfygo_views/diffusion_models/$name/transformer)"
    fi
  fi

  if [[ -d "$text_encoder_dir" ]]; then
    echo "    text_encoder payloads: $(count_model_payloads "$text_encoder_dir")"
  fi

  if [[ -d "$vae_dir" ]]; then
    echo "    vae payloads: $(count_model_payloads "$vae_dir")"
  fi
}

describe_diffusers_package() {
  local root="$1"
  local name="$2"

  describe_model_package "$root" "$root/diffusers/$name"
}

relative_link_target() {
  local src="$1"
  local dest="$2"
  local dest_dir

  dest_dir="$(dirname "$dest")"
  if command -v realpath >/dev/null 2>&1; then
    realpath -m --relative-to="$dest_dir" "$src"
  else
    printf '%s\n' "$src"
  fi
}

ensure_compat_link() {
  local src="$1"
  local dest="$2"
  local label="$3"
  local apply="$4"
  local target
  local current

  if [[ ! -d "$src" ]]; then
    return 0
  fi

  target="$(relative_link_target "$src" "$dest")"

  if [[ -L "$dest" ]]; then
    current="$(readlink "$dest")"
    if [[ "$current" == "$target" || "$(realpath -m "$(dirname "$dest")/$current")" == "$(realpath -m "$src")" ]]; then
      echo "    ok: $label -> $target"
      return 0
    fi
    echo "    conflict: $label already links to $current"
    return 1
  fi

  if [[ -e "$dest" ]]; then
    echo "    conflict: $label already exists and is not a symlink"
    return 1
  fi

  if [[ "$apply" == "1" ]]; then
    mkdir -p "$(dirname "$dest")"
    ln -s "$target" "$dest"
    echo "    linked: $label -> $target"
  else
    echo "    would link: $label -> $target"
  fi
}

model_compat_links_usage() {
  cat <<'EOF'
Usage:
  comfygo models reconcile -f FILTER [--apply]

Creates no files unless --apply is passed.

Full model folders self-identify through files such as model_index.json.
Compatibility views generated for ComfyUI's category-based loaders:
  diffusers/<name>/transformer   -> .comfygo_views/diffusion_models/<name>/transformer
  diffusers/<name>/text_encoder  -> .comfygo_views/text_encoders/<name>/text_encoder
  diffusers/<name>/vae           -> .comfygo_views/vae/<name>/vae
EOF
}

model_compat_links() {
  local filter=""
  local apply=0
  local root
  local package
  local name
  local label
  local matched=0
  local failed=0
  local old_nocasematch

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -f|--filter)
        if [[ $# -lt 2 ]]; then
          echo "$1 requires a filter value." >&2
          return 2
        fi
        if [[ -n "$filter" ]]; then
          echo "Only one filter is supported." >&2
          return 2
        fi
        filter="$2"
        shift
        ;;
      --filter=*)
        if [[ -n "$filter" ]]; then
          echo "Only one filter is supported." >&2
          return 2
        fi
        filter="${1#*=}"
        ;;
      --apply)
        apply=1
        ;;
      --dry-run)
        apply=0
        ;;
      -h|--help)
        model_compat_links_usage
        return 0
        ;;
      *)
        if [[ -n "$filter" ]]; then
          echo "Only one filter is supported." >&2
          return 2
        fi
        filter="$1"
        ;;
    esac
    shift
  done

  root="$(models_root)"
  echo "Models root: $root"
  if [[ "$apply" == "1" ]]; then
    echo "Mode: apply"
  else
    echo "Mode: dry-run"
  fi
  echo "Source of truth: model folders with model_index.json or comfygo-model.json"
  echo "Generated view: .comfygo_views/"

  old_nocasematch="$(shopt -p nocasematch || true)"
  shopt -s nocasematch
  while IFS= read -r package; do
    name="$(basename "$package")"
    label="${package#$root/}"
    if [[ -n "$filter" && "$name" != *"$filter"* && "$label" != *"$filter"* ]]; then
      continue
    fi

    matched=$((matched + 1))
    echo "  $label"
    ensure_compat_link "$package/transformer" "$root/.comfygo_views/diffusion_models/$name/transformer" ".comfygo_views/diffusion_models/$name/transformer" "$apply" || failed=1
    ensure_compat_link "$package/text_encoder" "$root/.comfygo_views/text_encoders/$name/text_encoder" ".comfygo_views/text_encoders/$name/text_encoder" "$apply" || failed=1
    ensure_compat_link "$package/vae" "$root/.comfygo_views/vae/$name/vae" ".comfygo_views/vae/$name/vae" "$apply" || failed=1
  done < <(print_model_packages "$root")
  eval "$old_nocasematch"

  if (( matched == 0 )); then
    echo "No matching self-identifying model packages found."
  elif [[ "$apply" != "1" ]]; then
    echo
    echo "Dry run only. Re-run with --apply to create compatibility views."
  fi

  return "$failed"
}

reconcile_model_views() {
  require_comfyui_dir
  require_uv
  "$repo_dir/scripts/comfygo-models.sh" \
    --models-dir "$(models_root)" \
    reconcile \
    --apply
}

run_model_registry_cli() {
  require_comfyui_dir
  require_uv
  "$repo_dir/scripts/comfygo-models.sh" \
    --models-dir "$(models_root)" \
    "$@"
}

model_inventory() {
  local filter=""
  local root
  local category
  local count
  local printed=0
  local old_nocasematch
  local name

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -f|--filter)
        if [[ $# -lt 2 ]]; then
          echo "$1 requires a filter value." >&2
          return 2
        fi
        if [[ -n "$filter" ]]; then
          echo "Only one filter is supported." >&2
          return 2
        fi
        filter="$2"
        shift
        ;;
      --filter=*)
        if [[ -n "$filter" ]]; then
          echo "Only one filter is supported." >&2
          return 2
        fi
        filter="${1#*=}"
        ;;
      -h|--help)
        usage
        return 0
        ;;
      *)
        if [[ -n "$filter" ]]; then
          echo "Only one filter is supported." >&2
          return 2
        fi
        filter="$1"
        ;;
    esac
    shift
  done

  root="$(models_root)"
  echo "Models root: $root"

  if [[ ! -d "$root" ]]; then
    echo "Models root does not exist."
    return 1
  fi

  if [[ -z "$filter" ]]; then
    echo "Top-level categories:"
    for category in "$root"/*; do
      [[ -d "$category" ]] || continue
      count="$(count_model_payloads "$category")"
      printf '  %s: %s payload files\n' "$(basename "$category")" "$count"
    done
    echo
    echo "Use: comfygo models -f <name-or-fragment>"
    return 0
  fi

  echo "Matches for: $filter"
  find "$root" -path '*/.git' -prune -o \( -type f -o -type l -o -type d \) \
    -iname "*$filter*" -printf '  %P\n' 2>/dev/null | sort | head -120

  if [[ -d "$root/diffusers" ]]; then
    echo
    echo "Diffusers package visibility checks:"
    old_nocasematch="$(shopt -p nocasematch || true)"
    shopt -s nocasematch
    for category in "$root"/diffusers/*; do
      [[ -d "$category" ]] || continue
      name="$(basename "$category")"
      if [[ "$name" == *"$filter"* ]]; then
        describe_diffusers_package "$root" "$name"
        printed=1
      fi
    done
    eval "$old_nocasematch"

    if (( printed == 0 )); then
      echo "  no matching full diffusers folder"
    fi
  fi
}

llama_cpp_runtime_status() {
  local python="$COMFYUI_DIR/.venv/bin/python"
  local module_check_code
  local cuda_check_code
  local attempt
  local module_log
  local probe_log
  local rc
  local uv_cache_dir

  if [[ ! -x "$python" ]]; then
    llama_cpp_status_result="not checked"
    return 0
  fi

  if ! command -v uv >/dev/null 2>&1; then
    llama_cpp_status_result="uv missing"
    return 1
  fi

  module_check_code=$'import importlib.util\n\nif importlib.util.find_spec("llama_cpp") is None:\n    raise SystemExit(42)\n'
  cuda_check_code=$'import llama_cpp\n\nllama_cpp.llama_print_system_info()\n'
  uv_cache_dir="${UV_CACHE_DIR:-${TMPDIR:-/tmp}/uv-cache}"
  mkdir -p "$uv_cache_dir"

  module_log="${TMPDIR:-/tmp}/comfy-local-llama-cpp-module.$$"
  if UV_CACHE_DIR="$uv_cache_dir" uv run --project "$COMFYUI_DIR" --python "$python" python -c "$module_check_code" >"$module_log" 2>&1; then
    rm -f "$module_log"
    :
  else
    rc=$?
    if [[ "$rc" == 42 ]]; then
      rm -f "$module_log"
      llama_cpp_status_result="not installed"
      return 0
    fi
    if [[ -s "$module_log" ]]; then
      echo "llama_cpp module probe log: $module_log" >&2
    else
      rm -f "$module_log"
    fi
    llama_cpp_status_result="failed(module rc=$rc)"
    return 1
  fi

  probe_log="${TMPDIR:-/tmp}/comfy-local-llama-cpp-probe.$$"
  : > "$probe_log"
  for attempt in 1 2; do
    if UV_CACHE_DIR="$uv_cache_dir" uv run --project "$COMFYUI_DIR" --python "$python" python -c "$cuda_check_code" >"$probe_log" 2>&1; then
      rm -f "$probe_log"
      llama_cpp_status_result="ok"
      return 0
    else
      rc=$?
    fi
  done

  if [[ -s "$probe_log" ]]; then
    echo "llama_cpp CUDA runtime probe log: $probe_log" >&2
  else
    rm -f "$probe_log"
  fi
  llama_cpp_status_result="failed(cuda rc=$rc)"
  return 1
}

snapshot_comfygo_views() {
  local model_root="$1"
  local views_root="$model_root/.comfygo_views"

  if [[ ! -e "$views_root" && ! -L "$views_root" ]]; then
    echo "__missing__"
    return 0
  fi

  find "$views_root" -printf '%y\t%P\t%l\n' 2>/dev/null | LC_ALL=C sort || true
}

# Guided doctor state (set by doctor_collect_readiness).
DOCTOR_GCD_PASS=0
DOCTOR_RUNTIME_ENVRC_MISSING=0
DOCTOR_SYNC_NEEDED=0
DOCTOR_RECONCILE_PENDING=0
DOCTOR_PATCH_COMFYUI_STATE="unknown"
DOCTOR_PATCH_CLI_STATE="unknown"
DOCTOR_MODEL_ROOT=""
DOCTOR_MODEL_ROOT_OK=0
DOCTOR_EVIDENCE_DIR=""

doctor_resolve_model_root() {
  local override="${1:-}"

  if [[ -n "$override" ]]; then
    DOCTOR_MODEL_ROOT="$override"
    return 0
  fi

  if [[ -z "${COMFYUI_DIR:-}" ]]; then
    DOCTOR_MODEL_ROOT=""
    return 1
  fi

  if [[ -n "${COMFY_MODELS_DIR:-}" ]]; then
    DOCTOR_MODEL_ROOT="$COMFY_MODELS_DIR"
  elif [[ -e "$COMFYUI_DIR/models" ]]; then
    DOCTOR_MODEL_ROOT="$COMFYUI_DIR/models"
  else
    DOCTOR_MODEL_ROOT="$(dirname "$COMFYUI_DIR")/models"
  fi
}

doctor_collect_readiness() {
  local models_override="${1:-}"
  local failed=0
  local llama_cpp_status_result
  local registry_cli_log
  local registry_cli_rc
  local registry_views_after
  local registry_views_before
  local registry_views_changed=0
  local uv_cache_dir
  local comfyui_patch
  local comfy_cli_patch
  local runtime_root

  DOCTOR_GCD_PASS=0
  DOCTOR_RUNTIME_ENVRC_MISSING=0
  DOCTOR_SYNC_NEEDED=0
  DOCTOR_RECONCILE_PENDING=0
  DOCTOR_PATCH_COMFYUI_STATE="unknown"
  DOCTOR_PATCH_CLI_STATE="unknown"
  DOCTOR_MODEL_ROOT_OK=0

  echo "Comfygo readiness"
  if [[ -n "$DOCTOR_EVIDENCE_DIR" ]]; then
    echo "Evidence: $DOCTOR_EVIDENCE_DIR"
  fi
  echo ""
  echo "Checks:"

  if command -v uv >/dev/null 2>&1; then
    echo "  PASS: uv available"
  else
    echo "  FAIL: uv missing"
    failed=1
  fi

  if [[ -z "${COMFYUI_DIR:-}" ]]; then
    echo "  FAIL: ComfyUI path not configured (COMFYUI_DIR unset)"
    failed=1
  elif [[ ! -d "$COMFYUI_DIR" ]]; then
    echo "  FAIL: ComfyUI path missing ($COMFYUI_DIR)"
    failed=1
  else
    echo "  PASS: ComfyUI path configured ($COMFYUI_DIR)"
    comfyui_patch="$(patch_state "$COMFYUI_DIR" "$repo_dir/comfyui-patches/comfy-sd-qwen-image-vae.patch")"
    DOCTOR_PATCH_COMFYUI_STATE="$comfyui_patch"
    if [[ "$comfyui_patch" == "applied" ]]; then
      echo "  PASS: ComfyUI patch applied"
    else
      echo "  NOTE: ComfyUI patch state: $comfyui_patch"
    fi

    runtime_root="$(comfy_runtime_root)"
    if [[ -f "$runtime_root/.envrc" ]]; then
      echo "  PASS: runtime direnv present"
    else
      echo "  NOTE: runtime direnv missing ($runtime_root/.envrc)"
      DOCTOR_RUNTIME_ENVRC_MISSING=1
    fi

    if [[ -f "$repo_dir/custom_nodes/comfygo_model_registry/__init__.py" ]]; then
      echo "  PASS: model registry source present"
    else
      echo "  FAIL: model registry source missing"
      failed=1
    fi

    if [[ -f "$COMFYUI_DIR/custom_nodes/comfygo_model_registry/__init__.py" ]]; then
      echo "  PASS: model registry runtime copy present"
      echo "Model registry runtime copy: present"
    else
      echo "  FAIL: model registry runtime copy missing"
      echo "Model registry runtime copy: missing"
      failed=1
    fi

    if expected_node_status >/dev/null 2>&1; then
      echo "  PASS: expected nodes present"
    else
      echo "  NOTE: expected nodes missing"
      DOCTOR_SYNC_NEEDED=1
      expected_node_status || true
    fi

    load_runtime_direnv_env
    prepare_comfyui_runtime_env
    if llama_cpp_runtime_status; then
      echo "  PASS: llama_cpp CUDA runtime ($llama_cpp_status_result)"
    else
      echo "  FAIL: llama_cpp CUDA runtime ($llama_cpp_status_result)"
      failed=1
    fi
  fi

  if [[ -z "${COMFY_CLI_DIR:-}" ]]; then
    echo "  FAIL: comfy-cli path not configured"
    failed=1
  elif [[ ! -d "$COMFY_CLI_DIR" ]]; then
    echo "  FAIL: comfy-cli path missing ($COMFY_CLI_DIR)"
    failed=1
  else
    echo "  PASS: comfy-cli path configured"
    comfy_cli_patch="$(patch_state "$COMFY_CLI_DIR" "$repo_dir/comfy-cli-patches/add-local-nodes-command.patch")"
    DOCTOR_PATCH_CLI_STATE="$comfy_cli_patch"
    if [[ "$comfy_cli_patch" == "applied" ]]; then
      echo "  PASS: comfy-cli patch applied"
    else
      echo "  NOTE: comfy-cli patch state: $comfy_cli_patch"
    fi
  fi

  if doctor_resolve_model_root "$models_override"; then
    if [[ -d "$DOCTOR_MODEL_ROOT" && -r "$DOCTOR_MODEL_ROOT" ]]; then
      echo "  PASS: model root readable ($DOCTOR_MODEL_ROOT)"
      DOCTOR_MODEL_ROOT_OK=1
    else
      echo "  FAIL: model root unreadable ($DOCTOR_MODEL_ROOT)"
      failed=1
    fi
  else
    echo "  FAIL: model root unknown (configure COMFYUI_DIR or --models-dir)"
    failed=1
  fi

  if command -v uv >/dev/null 2>&1 && (( DOCTOR_MODEL_ROOT_OK )); then
    registry_cli_log="${TMPDIR:-/tmp}/comfygo-model-registry-doctor.$$"
    registry_views_before="${TMPDIR:-/tmp}/comfygo-model-registry-views-before.$$"
    registry_views_after="${TMPDIR:-/tmp}/comfygo-model-registry-views-after.$$"
    uv_cache_dir="${UV_CACHE_DIR:-${TMPDIR:-/tmp}/uv-cache}"
    mkdir -p "$uv_cache_dir"
    snapshot_comfygo_views "$DOCTOR_MODEL_ROOT" >"$registry_views_before"
    if UV_CACHE_DIR="$uv_cache_dir" "$repo_dir/scripts/comfygo-models.sh" \
      --models-dir "$DOCTOR_MODEL_ROOT" reconcile >"$registry_cli_log" 2>&1; then
      registry_cli_rc=0
    else
      registry_cli_rc=$?
    fi
    snapshot_comfygo_views "$DOCTOR_MODEL_ROOT" >"$registry_views_after"
    if ! cmp -s "$registry_views_before" "$registry_views_after"; then
      registry_views_changed=1
      failed=1
      echo "  FAIL: model registry dry-run changed .comfygo_views"
      echo "Model registry CLI dry-run: changed .comfygo_views (log: $registry_cli_log)"
    else
      rm -f "$registry_views_before" "$registry_views_after"
    fi
    if [[ "$registry_cli_rc" -eq 0 ]]; then
      if grep -qi -E 'created|pruned|conflict' "$registry_cli_log" 2>/dev/null; then
        echo "  FAIL: model registry dry-run pending changes"
        echo "Model registry CLI dry-run: pending changes (log: $registry_cli_log)"
        DOCTOR_RECONCILE_PENDING=1
        failed=1
      elif (( registry_views_changed )); then
        echo "  FAIL: model registry dry-run side-effect"
      else
        echo "  PASS: model registry dry-run"
        echo "Model registry CLI dry-run: ok"
        rm -f "$registry_cli_log"
      fi
    else
      echo "  FAIL: model registry dry-run command failed"
      echo "Model registry CLI dry-run: failed (log: $registry_cli_log)"
      failed=1
    fi
  fi

  echo ""
  echo "GC temp-root doctor:"
  local gcd_log="${DOCTOR_EVIDENCE_DIR}/gcd-harness.log"
  if COMFYGO_GCD_EVIDENCE_DIR="$DOCTOR_EVIDENCE_DIR" \
    "$repo_dir/scripts/comfygo-gcd-harness.sh" >"$gcd_log" 2>&1; then
    sed 's/^/  /' <"$gcd_log"
    echo "  PASS: GC temp-root doctor"
    DOCTOR_GCD_PASS=1
  else
    sed 's/^/  /' <"$gcd_log"
    echo "  FAIL: GC temp-root doctor"
    failed=1
  fi

  if (( DOCTOR_MODEL_ROOT_OK )); then
    echo ""
    echo "Live model-root GC dry-run:"
    local live_log="${TMPDIR:-/tmp}/comfygo-doctor-live-gc.$$"
    local trash_before="${TMPDIR:-/tmp}/comfygo-doctor-trash-before.$$"
    if [[ -d "$DOCTOR_MODEL_ROOT/.comfygo_trash" ]]; then
      find "$DOCTOR_MODEL_ROOT/.comfygo_trash" -mindepth 1 -maxdepth 3 -print | sort >"$trash_before"
    else
      : >"$trash_before"
    fi
    if UV_CACHE_DIR="${UV_CACHE_DIR:-${TMPDIR:-/tmp}/uv-cache}" \
      "$repo_dir/scripts/comfygo-models.sh" --models-dir "$DOCTOR_MODEL_ROOT" gc >"$live_log" 2>&1; then
      local trash_after="${TMPDIR:-/tmp}/comfygo-doctor-trash-after.$$"
      if [[ -d "$DOCTOR_MODEL_ROOT/.comfygo_trash" ]]; then
        find "$DOCTOR_MODEL_ROOT/.comfygo_trash" -mindepth 1 -maxdepth 3 -print | sort >"$trash_after"
      else
        : >"$trash_after"
      fi
      if cmp -s "$trash_before" "$trash_after"; then
        echo "  PASS: live model-root GC dry-run (read-only)"
        rm -f "$live_log" "$trash_before" "$trash_after"
      else
        echo "  FAIL: live model-root GC dry-run mutated .comfygo_trash"
        failed=1
      fi
    else
      echo "  FAIL: live model-root GC dry-run command failed (log: $live_log)"
      failed=1
    fi
  else
    echo ""
    echo "Live model-root GC dry-run:"
    echo "  SKIP: live model root unknown"
  fi

  return "$failed"
}

doctor_action_status() {
  local action="$1"
  local gcd_gate_ok=0

  if (( DOCTOR_GCD_PASS )); then
    gcd_gate_ok=1
  fi

  case "$action" in
    runtime-envrc)
      if [[ -z "${COMFYUI_DIR:-}" ]]; then
        echo "blocked|configure COMFYUI_DIR first"
      elif (( DOCTOR_RUNTIME_ENVRC_MISSING )); then
        echo "available|runtime direnv missing"
      else
        echo "not relevant|runtime direnv already present"
      fi
      ;;
    sync)
      if (( ! gcd_gate_ok )); then
        echo "blocked|PASS: all 16 GCD scenarios required"
      elif [[ -z "${COMFYUI_DIR:-}" ]]; then
        echo "blocked|configure COMFYUI_DIR first"
      elif (( DOCTOR_SYNC_NEEDED )); then
        echo "available|runtime custom_nodes copy is stale or missing"
      else
        echo "not relevant|expected nodes already present"
      fi
      ;;
    patch-comfyui)
      if (( ! gcd_gate_ok )); then
        echo "blocked|PASS: all 16 GCD scenarios required"
      elif [[ -z "${COMFYUI_DIR:-}" ]]; then
        echo "blocked|configure COMFYUI_DIR first"
      elif (( DOCTOR_SYNC_NEEDED )); then
        echo "blocked|sync"
      elif [[ "$DOCTOR_PATCH_COMFYUI_STATE" == "not applied" ]]; then
        echo "available|ComfyUI patch not applied"
      elif [[ "$DOCTOR_PATCH_COMFYUI_STATE" == "applied" ]]; then
        echo "not relevant|ComfyUI patch already applied"
      else
        echo "blocked|ComfyUI patch state: $DOCTOR_PATCH_COMFYUI_STATE"
      fi
      ;;
    patch-cli)
      if (( ! gcd_gate_ok )); then
        echo "blocked|PASS: all 16 GCD scenarios required"
      elif [[ -z "${COMFY_CLI_DIR:-}" ]]; then
        echo "blocked|configure COMFY_CLI_DIR first"
      elif [[ "$DOCTOR_PATCH_CLI_STATE" == "not applied" ]]; then
        echo "available|comfy-cli patch not applied"
      elif [[ "$DOCTOR_PATCH_CLI_STATE" == "applied" ]]; then
        echo "not relevant|comfy-cli patch already applied"
      else
        echo "blocked|comfy-cli patch state: $DOCTOR_PATCH_CLI_STATE"
      fi
      ;;
    reconcile)
      if (( ! gcd_gate_ok )); then
        echo "blocked|PASS: all 16 GCD scenarios required"
      elif (( ! DOCTOR_MODEL_ROOT_OK )); then
        echo "blocked|model root unreadable"
      elif (( DOCTOR_RECONCILE_PENDING )); then
        echo "available|reconcile dry-run reports pending changes"
      elif [[ "$DOCTOR_PATCH_COMFYUI_STATE" != "applied" ]]; then
        echo "blocked|patch-comfyui"
      else
        echo "not relevant|no pending reconcile changes"
      fi
      ;;
    targeted-gc)
      if (( ! gcd_gate_ok )); then
        echo "blocked|PASS: all 16 GCD scenarios required"
      elif (( ! DOCTOR_MODEL_ROOT_OK )); then
        echo "blocked|model root unreadable"
      else
        echo "blocked|choose a unique managed folder with --gc-target"
      fi
      ;;
    launch|restart)
      if (( ! gcd_gate_ok )); then
        echo "blocked|PASS: all 16 GCD scenarios required"
      elif [[ -z "${COMFYUI_DIR:-}" || -z "${COMFY_CLI_DIR:-}" ]]; then
        echo "blocked|configure COMFYUI_DIR and COMFY_CLI_DIR"
      elif (( DOCTOR_SYNC_NEEDED )); then
        echo "blocked|sync"
      elif [[ "$DOCTOR_PATCH_COMFYUI_STATE" != "applied" ]]; then
        echo "blocked|patch-comfyui"
      elif [[ "$DOCTOR_PATCH_CLI_STATE" != "applied" ]]; then
        echo "blocked|patch-cli"
      elif (( DOCTOR_RECONCILE_PENDING )); then
        echo "blocked|reconcile"
      else
        echo "available|prerequisites satisfied"
      fi
      ;;
    install|update|refresh-upstreams)
      echo "not relevant|only when explicitly requested"
      ;;
    *)
      echo "blocked|unknown action id"
      ;;
  esac
}

doctor_print_actions() {
  local action
  local status_line
  local status
  local reason

  echo ""
  echo "Actions:"
  for action in runtime-envrc sync patch-comfyui patch-cli reconcile targeted-gc launch restart install update refresh-upstreams; do
    status_line="$(doctor_action_status "$action")"
    status="${status_line%%|*}"
    reason="${status_line#*|}"
    printf '  %-18s %s\n' "$status" "$action"
    if [[ "$status" == "available" ]]; then
      echo "    run: scripts/comfygo doctor --apply $action"
    elif [[ -n "$reason" ]]; then
      echo "    reason: $reason"
    fi
  done
}

doctor_recommended_action() {
  local action
  local status_line
  local status

  for action in runtime-envrc sync patch-comfyui patch-cli reconcile launch; do
    status_line="$(doctor_action_status "$action")"
    status="${status_line%%|*}"
    if [[ "$status" == "available" ]]; then
      echo "$action|${status_line#*|}"
      return 0
    fi
  done
  return 1
}

doctor_confirm_apply() {
  local action="$1"
  local assume_yes="$2"

  if (( assume_yes )); then
    return 0
  fi
  if [[ ! -t 0 ]]; then
    echo "Refused --apply $action in non-interactive mode without --yes" >&2
    return 2
  fi
  read -r -p "Run $action now? [y/N] " reply
  case "$reply" in
    y|Y|yes|YES) return 0 ;;
    *) echo "Aborted." >&2; return 2 ;;
  esac
}

doctor_apply_action() {
  local action="$1"
  local assume_yes="$2"
  local gc_target="$3"
  local models_override="$4"
  local status_line
  local status
  local reason
  local failed=0

  status_line="$(doctor_action_status "$action")"
  status="${status_line%%|*}"
  reason="${status_line#*|}"

  if [[ "$action" == "gc-target" ]]; then
    echo "Unknown action id: gc-target (use targeted-gc with --gc-target)" >&2
    return 2
  fi

  if [[ "$status" != "available" ]]; then
    echo "Refused --apply $action: $status ($reason)" >&2
    return 2
  fi

  doctor_confirm_apply "$action" "$assume_yes" || return $?

  case "$action" in
    runtime-envrc)
      write_runtime_envrc
      ;;
    sync)
      require_comfyui_dir
      COMFYUI_DIR="$COMFYUI_DIR" "$repo_dir/scripts/install-to-comfyui.sh"
      ;;
    patch-comfyui)
      require_comfyui_dir
      COMFYUI_DIR="$COMFYUI_DIR" "$repo_dir/scripts/apply-comfyui-patches.sh"
      ;;
    patch-cli)
      require_comfy_cli_dir
      COMFY_CLI_DIR="$COMFY_CLI_DIR" "$repo_dir/scripts/apply-comfy-cli-patches.sh"
      ;;
    reconcile)
      require_comfyui_dir
      doctor_resolve_model_root "$models_override" || return 1
      UV_CACHE_DIR="${UV_CACHE_DIR:-${TMPDIR:-/tmp}/uv-cache}" \
        "$repo_dir/scripts/comfygo-models.sh" --models-dir "$DOCTOR_MODEL_ROOT" reconcile --apply
      ;;
    targeted-gc)
      if [[ -z "$gc_target" ]]; then
        echo "targeted-gc requires --gc-target <name>" >&2
        return 2
      fi
      doctor_resolve_model_root "$models_override" || return 1
      UV_CACHE_DIR="${UV_CACHE_DIR:-${TMPDIR:-/tmp}/uv-cache}" \
        "$repo_dir/scripts/comfygo-models.sh" --models-dir "$DOCTOR_MODEL_ROOT" gc -f "$gc_target" --apply
      ;;
    launch)
      full_launch_sequence
      ;;
    restart)
      restart_comfyui
      ;;
    install)
      require_comfyui_dir
      require_comfy_cli_dir
      require_uv
      COMFYUI_DIR="$COMFYUI_DIR" COMFY_CLI_DIR="$COMFY_CLI_DIR" "$repo_dir/scripts/comfy-install-with-local-nodes.sh"
      ;;
    update)
      require_comfyui_dir
      require_comfy_cli_dir
      require_uv
      COMFYUI_DIR="$COMFYUI_DIR" COMFY_CLI_DIR="$COMFY_CLI_DIR" "$repo_dir/scripts/comfy-update-with-local-nodes.sh"
      ;;
    refresh-upstreams)
      "$repo_dir/scripts/update-from-upstreams.sh"
      ;;
    *)
      echo "Unknown action id: $action" >&2
      return 2
      ;;
  esac
}

doctor_usage() {
  cat <<'EOF'
Usage:
  scripts/comfygo doctor [options]

Options:
  --models-dir PATH   Use explicit model root for read-only checks
  --apply ACTION      Run a catalog action when marked available
  --gc-target NAME    Required with --apply targeted-gc
  --yes               Non-interactive confirmation for --apply
  --keep-evidence     Retain evidence directory (printed in output)
  --smoke-repatch     Run scripts/test-repatch-smoke.sh after readiness
  -h, --help          Show this help

Action IDs:
  runtime-envrc, sync, patch-comfyui, patch-cli, reconcile, targeted-gc,
  launch, restart, install, update, refresh-upstreams
EOF
}

doctor() {
  local models_override=""
  local apply_action=""
  local gc_target=""
  local assume_yes=0
  local keep_evidence=0
  local smoke_repatch=0
  local arg
  local failed=0
  local rec_line
  local rec_action
  local rec_reason

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        doctor_usage
        return 0
        ;;
      --models-dir)
        [[ $# -ge 2 ]] || {
          echo "doctor: --models-dir requires a path" >&2
          return 2
        }
        models_override="$2"
        shift 2
        ;;
      --apply)
        [[ $# -ge 2 ]] || {
          echo "doctor: --apply requires an action id" >&2
          return 2
        }
        apply_action="$2"
        shift 2
        ;;
      --gc-target)
        [[ $# -ge 2 ]] || {
          echo "doctor: --gc-target requires a name" >&2
          return 2
        }
        gc_target="$2"
        shift 2
        ;;
      --yes)
        assume_yes=1
        shift
        ;;
      --keep-evidence)
        keep_evidence=1
        shift
        ;;
      --smoke-repatch)
        smoke_repatch=1
        shift
        ;;
      --full-gcd)
        shift
        ;;
      *)
        echo "doctor: unknown option: $1" >&2
        return 2
        ;;
    esac
  done

  if [[ -n "$apply_action" ]]; then
    if (( keep_evidence )); then
      DOCTOR_EVIDENCE_DIR="$(mktemp -d /tmp/comfygo-doctor.XXXXXX)"
    else
      DOCTOR_EVIDENCE_DIR="$(mktemp -d /tmp/comfygo-doctor.XXXXXX)"
      trap 'rm -rf "$DOCTOR_EVIDENCE_DIR"' RETURN
    fi
    doctor_collect_readiness "$models_override" || failed=1
    doctor_apply_action "$apply_action" "$assume_yes" "$gc_target" "$models_override"
    return $?
  fi

  if (( keep_evidence )); then
    DOCTOR_EVIDENCE_DIR="$(mktemp -d /tmp/comfygo-doctor.XXXXXX)"
  else
    DOCTOR_EVIDENCE_DIR="$(mktemp -d /tmp/comfygo-doctor.XXXXXX)"
    trap 'rm -rf "$DOCTOR_EVIDENCE_DIR"' RETURN
  fi

  doctor_collect_readiness "$models_override" || failed=1
  doctor_print_actions

  echo ""
  echo "Recommended next action:"
  if rec_line="$(doctor_recommended_action)"; then
    rec_action="${rec_line%%|*}"
    rec_reason="${rec_line#*|}"
    echo "  $rec_action - $rec_reason"
    echo "  To run: scripts/comfygo doctor --apply $rec_action"
  else
    echo "  (none - all catalog actions blocked or not relevant)"
  fi

  if (( smoke_repatch )); then
    echo ""
    echo "Smoke: re-patch verification"
    bash "$repo_dir/scripts/test-repatch-smoke.sh" || failed=1
  fi

  return "$failed"
}

ensure_comfy_cli_patch() {
  local patch="$repo_dir/comfy-cli-patches/add-local-nodes-command.patch"

  if [[ ! -f "$patch" || ! -d "$COMFY_CLI_DIR/.git" ]]; then
    return
  fi

  if git -C "$COMFY_CLI_DIR" apply --reverse --check "$patch" >/dev/null 2>&1; then
    echo "comfy-cli patch: applied"
  elif git -C "$COMFY_CLI_DIR" apply --check "$patch" >/dev/null 2>&1; then
    COMFY_CLI_DIR="$COMFY_CLI_DIR" "$repo_dir/scripts/apply-comfy-cli-patches.sh"
  else
    echo "comfy-cli patch: does not apply cleanly; continuing with wrapper launch" >&2
  fi
}

launch_comfyui() {
  require_comfyui_dir
  require_comfy_cli_dir
  require_uv
  load_runtime_direnv_env
  prepare_comfyui_runtime_env
  reconcile_model_views
  COMFYUI_DIR="$COMFYUI_DIR" "$repo_dir/scripts/install-to-comfyui.sh"
  expected_node_status
  if [[ $# -eq 0 ]]; then
    set -- --listen 127.0.0.1 --port 8188
  fi
  echo "Browser: refresh any already-open ComfyUI tab after the backend finishes starting."
  cd "$COMFY_CLI_DIR"
  exec uv run comfy --workspace "$COMFYUI_DIR" launch -- "$@"
}

# T015: Tmux helpers for US2
# Use COMFYGO_LAUNCH_TMUX_NAME from settings.
tmux_target() {
  echo "${COMFYGO_LAUNCH_TMUX_NAME:-comfyui}"
}

tmux_launch() {
  local name=$(tmux_target)
  require_comfyui_dir
  require_comfy_cli_dir
  require_uv
  load_runtime_direnv_env
  prepare_comfyui_runtime_env
  reconcile_model_views
  COMFYUI_DIR="$COMFYUI_DIR" "$repo_dir/scripts/install-to-comfyui.sh"
  expected_node_status
  if [[ $# -eq 0 ]]; then
    set -- --listen 127.0.0.1 --port 8188
  fi
  echo "Browser: refresh any already-open ComfyUI tab after the backend finishes starting."
  if command -v tmux >/dev/null 2>&1; then
    # Launch in tmux window, controlling shell stays free
    tmux new-window -n "$name" -d "cd $COMFY_CLI_DIR && uv run comfy --workspace $COMFYUI_DIR launch -- $*"
    echo "Launched ComfyUI in tmux window '$name'. Use 'tmux attach -t $(tmux_target)' or control via helpers."
    echo "Target recorded: $name"
  else
    echo "tmux not found, falling back to direct launch (see T017)."
    cd "$COMFY_CLI_DIR"
    exec uv run comfy --workspace "$COMFYUI_DIR" launch -- "$@"
  fi
}

tmux_send_command() {
  local name=$(tmux_target)
  if command -v tmux >/dev/null 2>&1; then
    tmux send-keys -t "$name" "$*" C-m
    echo "Sent to tmux '$name': $*"
  else
    echo "tmux not available for send-command."
  fi
}

# T014 / T032: strict sequence for launch
# update/patch (US1) -> verify (incl protection) -> tmux launch
full_launch_sequence() {
  echo "=== 004 Full Sequence: update/patch -> verify -> tmux launch ==="
  # US1 patching
  COMFYUI_DIR="$COMFYUI_DIR" "$repo_dir/scripts/install-to-comfyui.sh" || true
  # re-patch using enhanced driver (T059 / T081): conditional based on structured manifest parse (Historical Names), per Error and Exit Contracts
  # Edge case handling per spec (FR-002, Edge Cases, FR-005): MUST NOT disrupt running ComfyUI unless explicitly requested.
  # Check if tmux target active; if yes, skip re-patch (user can use doctor --apply or explicit).
  tmux_name=$(tmux_target 2>/dev/null || echo "comfyui")
  if command -v tmux >/dev/null 2>&1 && tmux has-session -t "$tmux_name" 2>/dev/null; then
    echo "Tmux target '$tmux_name' is active. Skipping re-patch to avoid disrupting running ComfyUI (per spec edge case). Use 'comfygo doctor --apply patch-comfyui' or restart with explicit re-patch if needed."
  else
    for pdir in "$repo_dir/comfyui-patches" "$repo_dir/comfy-cli-patches"; do
      if [[ -f "$pdir/manifest.md" ]]; then
        echo "Checking drift for $pdir..."
        local drift_output
        drift_output=$(patch_drift_check "$COMFYUI_DIR" "$pdir" 2>/dev/null || true)
        echo "$drift_output"
        # conditional re-apply if any "not applied" (now with exact contract message from enhanced driver)
        if echo "$drift_output" | grep -q "not applied"; then
          echo "Drift/mismatch detected in $pdir, re-applying per manifest (see exact ACTION REQUIRED messages above)..."
          if [[ "$pdir" == *comfyui* ]]; then
            COMFYUI_DIR="$COMFYUI_DIR" "$repo_dir/scripts/apply-comfyui-patches.sh" || true
          else
            COMFY_CLI_DIR="$COMFY_CLI_DIR" "$repo_dir/scripts/apply-comfy-cli-patches.sh" || true
          fi
        fi
      fi
    done
  fi
  # US3 enrichment if enabled (T058 / T080)
  if [[ "${COMFYGO_ENRICH_CIVITAI:-0}" == "1" ]]; then
    echo "=== Model enrichment (Civitai/HF) ==="
    model_root="$(models_root 2>/dev/null || echo "")"
    if [[ -n "$model_root" && -d "$model_root" && -r "$model_root" ]]; then
      # Actually call the enrich helper (not stub) for auto-enrichment during launch.
      # Uses --only-missing to skip existing, writes rich descriptor + metadata + side folder if applicable.
      # Graceful degradation on no token / failure per FR-008, Key Entities (basic usable local descriptor).
      # uv-first, respects direnv tokens.
      uv run --no-project python3 "$repo_dir/scripts/hf_select_download.py" \
        --models-root "$model_root" \
        --only-missing \
        --write-descriptor \
        --write-metadata \
        --package-name "auto-enrich" 2>&1 || echo "Enrichment skipped or partial (no token, no match, or error - see FR-008 graceful basic descriptor)"
    else
      echo "No readable model root for auto-enrich (COMFY_MODELS_DIR or sibling of COMFYUI_DIR)"
    fi
  fi
  # NOTE: full verify-quality.sh (lint/tests) removed from launch sequence per safety (belongs in pre-commit per AGENTS/IX; was risking aborting user launches).
  # Launch verification is now the feature-state checks (paths, patches, drift, registry, etc.) done earlier in sequence.
  # protection check if in doctor
  # launch
  if [[ "${COMFYGO_USE_TMUX:-1}" == "1" ]]; then
    tmux_launch "$@"
  else
    launch_comfyui "$@"
  fi
}

restart_comfyui() {
  require_comfyui_dir
  require_comfy_cli_dir
  require_uv
  load_runtime_direnv_env
  prepare_comfyui_runtime_env
  reconcile_model_views
  ensure_comfy_cli_patch
  COMFYUI_DIR="$COMFYUI_DIR" "$repo_dir/scripts/install-to-comfyui.sh"
  expected_node_status
  cd "$COMFY_CLI_DIR"
  uv run comfy --workspace "$COMFYUI_DIR" stop || true
  if [[ $# -eq 0 ]]; then
    set -- --listen 127.0.0.1 --port 8188
  fi
  echo "Browser: refresh any already-open ComfyUI tab after the backend finishes starting."
  exec uv run comfy --workspace "$COMFYUI_DIR" launch -- "$@"
}

command="${1:-help}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$command" in
  help|-h|--help)
    usage
    ;;

  go)
    require_comfyui_dir
    require_comfy_cli_dir
    ensure_comfy_cli_patch
    # T014: use full sequence for go
    full_launch_sequence "$@"
    ;;

  doctor)
    doctor "$@"
    ;;

  status)
    echo "Vendored repo: $repo_dir"
    echo "Env source: $env_source"
    echo "COMFYUI_DIR: ${COMFYUI_DIR:-not set}"
    echo "COMFY_CLI_DIR: ${COMFY_CLI_DIR:-not set}"

    if [[ -n "${COMFYUI_DIR:-}" ]]; then
      echo "ComfyUI exists: $([[ -d "$COMFYUI_DIR" ]] && echo yes || echo no)"
      echo "ComfyUI patch: $(patch_state "$COMFYUI_DIR" "$repo_dir/comfyui-patches/comfy-sd-qwen-image-vae.patch")"
      patch_drift_check "$COMFYUI_DIR" "$repo_dir/comfyui-patches"
    fi

    if [[ -n "${COMFY_CLI_DIR:-}" ]]; then
      echo "comfy-cli exists: $([[ -d "$COMFY_CLI_DIR" ]] && echo yes || echo no)"
      echo "comfy-cli patch: $(patch_state "$COMFY_CLI_DIR" "$repo_dir/comfy-cli-patches/add-local-nodes-command.patch")"
      patch_drift_check "$COMFY_CLI_DIR" "$repo_dir/comfy-cli-patches"
    fi
    ;;

  models)
    if [[ "${1:-}" == "enrich" ]]; then
      shift
      # T058: expose as `comfygo models enrich` and integrate Civitai/HF (uv-first)
      uv run --no-project python3 "$repo_dir/scripts/hf_select_download.py" "$@"
    else
      run_model_registry_cli "$@"
    fi
    ;;

  sync)
    require_comfyui_dir
    COMFYUI_DIR="$COMFYUI_DIR" "$repo_dir/scripts/install-to-comfyui.sh" "$@"
    ;;

  start|launch)
    full_launch_sequence "$@"
    ;;

  restart)
    restart_comfyui "$@"
    ;;

  update)
    require_comfyui_dir
    require_comfy_cli_dir
    require_uv
    COMFYUI_DIR="$COMFYUI_DIR" COMFY_CLI_DIR="$COMFY_CLI_DIR" "$repo_dir/scripts/comfy-update-with-local-nodes.sh" "$@"
    ;;

  install)
    require_comfyui_dir
    require_comfy_cli_dir
    require_uv
    COMFYUI_DIR="$COMFYUI_DIR" COMFY_CLI_DIR="$COMFY_CLI_DIR" "$repo_dir/scripts/comfy-install-with-local-nodes.sh" "$@"
    ;;

  patch-cli)
    require_comfy_cli_dir
    COMFY_CLI_DIR="$COMFY_CLI_DIR" "$repo_dir/scripts/apply-comfy-cli-patches.sh" "$@"
    ;;

  patch-comfyui)
    require_comfyui_dir
    COMFYUI_DIR="$COMFYUI_DIR" "$repo_dir/scripts/apply-comfyui-patches.sh" "$@"
    ;;

  tmux-send)
    shift
    tmux_send_command "$@"
    ;;

  refresh-upstreams)
    "$repo_dir/scripts/update-from-upstreams.sh" "$@"
    ;;

  runtime-envrc)
    require_comfyui_dir
    write_runtime_envrc
    ;;

  *)
    echo "Unknown command: $command" >&2
    usage >&2
    exit 2
    ;;
esac
