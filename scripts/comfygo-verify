#!/usr/bin/env bash
# comfygo-verify — single entry point for all automatable checks.
#
# Phases:
#   1. Pre-flight   — git status, shell syntax, whitespace
#   2. Repo tests   — uv run pytest (full suite)
#   3. GC doctor    — 16 GCD scenarios in isolated temp root
#   4. Live validate — delegates to comfygo-live-validate (optional)
#
# Usage:
#   scripts/comfygo-verify                    # all phases (default)
#   scripts/comfygo-verify --fast             # skip GC doctor + live
#   scripts/comfygo-verify --help             # show this help
#
# Environment:
#   COMFYUI_DIR   — set to run live validation phase
#   COMFY_CLI_DIR — passed through to live-validate
#
# Exit codes:
#   0 — all checks passed
#   1 — one or more checks failed

set -u

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

usage() {
    cat <<EOF
Usage:
  scripts/comfygo-verify [--fast] [--help]

Options:
  --fast      Run pre-flight and repository tests only; skip GC doctor and live validation.
  -h, --help  Show this help.

Environment:
  COMFYUI_DIR   Set to run live validation phase.
  COMFY_CLI_DIR Passed through to live validation.
EOF
}

skip_gc=false
skip_live=false
while [[ $# -gt 0 ]]; do
    case "$1" in
        --fast)
            skip_gc=true
            skip_live=true
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "error: unknown argument: $1" >&2
            usage >&2
            exit 2
            ;;
    esac
done

# ── Evidence directory ──────────────────────────────────────────────
run_dir="$(mktemp -d /tmp/comfygo-verify.XXXXXX)" || {
    echo "FATAL: could not create evidence directory" >&2
    exit 1
}
echo "Evidence: $run_dir"

# ── Fail accumulator ────────────────────────────────────────────────
failed=0
current_phase="setup"
declare -A phase_pass_counts=()
declare -A phase_fail_counts=()
declare -A phase_skip_counts=()

increment_phase_count() {
    local bucket="$1"
    local phase="$current_phase"
    case "$bucket" in
        pass)
            phase_pass_counts[$phase]=$((${phase_pass_counts[$phase]:-0} + 1))
            ;;
        fail)
            phase_fail_counts[$phase]=$((${phase_fail_counts[$phase]:-0} + 1))
            ;;
        skip)
            phase_skip_counts[$phase]=$((${phase_skip_counts[$phase]:-0} + 1))
            ;;
    esac
}

start_phase() {
    current_phase="$1"
    local title="$2"
    echo ""
    echo "--- $title ---"
}

record_pass() {
    local msg="$1"
    echo "  PASS: $msg"
    increment_phase_count pass
}

record_skip() {
    local msg="$1"
    echo "  SKIP: $msg"
    increment_phase_count skip
}

record_fail() {
    local msg="$1"
    echo "  FAIL: $msg"
    failed=1
    increment_phase_count fail
}

print_phase_summary() {
    echo ""
    echo "--- Summary ---"
    for phase in phase1 phase2 phase3 phase4; do
        local label
        case "$phase" in
            phase1) label="Pre-flight" ;;
            phase2) label="Repository tests" ;;
            phase3) label="GC doctor" ;;
            phase4) label="Live validation" ;;
        esac
        echo "  $label: ${phase_pass_counts[$phase]:-0} pass, ${phase_fail_counts[$phase]:-0} fail, ${phase_skip_counts[$phase]:-0} skip"
    done
}

# ── Phase 1: Pre-flight ─────────────────────────────────────────────
start_phase "phase1" "Phase 1: Pre-flight"

# 1a: git status --porcelain must be clean
pre_git_log="$run_dir/git-status-before.log"
preflight_git_clean=true
if git -C "$REPO_DIR" status --porcelain=v1 --untracked-files=all \
    > "$pre_git_log" 2>&1; then
    if [ -s "$pre_git_log" ]; then
        preflight_git_clean=false
        record_fail "repo is dirty — clean it first"
        cat "$pre_git_log"
    else
        record_pass "git status clean"
    fi
else
    preflight_git_clean=false
    record_fail "git status failed"
fi

# 1b: bash -n on all shell scripts in scripts/
shell_syntax_ok=true
for script in \
    "$SCRIPT_DIR"/*.sh \
    "$SCRIPT_DIR/comfygo-verify" \
    "$SCRIPT_DIR/comfygo-live-validate" \
    "$SCRIPT_DIR/comfy-local"
do
    [ -f "$script" ] || continue
    if bash -n "$script" 2>/dev/null; then
        :  # OK
    else
        shell_syntax_ok=false
        record_fail "bash -n $script failed"
    fi
done
if [ "$shell_syntax_ok" = true ]; then
    record_pass "all shell scripts pass bash -n"
fi

# 1c: git diff --check
if git -C "$REPO_DIR" diff --check 2>/dev/null; then
    record_pass "git diff --check clean"
else
    record_fail "whitespace/merge conflicts in working tree"
fi

# 1d: no tracked pycache/bytecode artifacts
tracked_pycache_log="$run_dir/tracked-pycache.log"
git -C "$REPO_DIR" ls-files \
    '*/__pycache__/*' \
    '*.pyc' \
    '*.pyo' \
    > "$tracked_pycache_log"
if [ -s "$tracked_pycache_log" ]; then
    record_fail "tracked Python cache artifacts found"
    cat "$tracked_pycache_log"
else
    record_pass "no tracked Python cache artifacts"
fi

# ── Phase 2: Repository tests ───────────────────────────────────────
start_phase "phase2" "Phase 2: Repository tests"

test_log="$run_dir/pytest.log"
if UV_CACHE_DIR="${UV_CACHE_DIR:-/tmp/uv-cache}" \
    uv run pytest custom_nodes/comfygo_model_registry/tests \
    -q --tb=line > "$test_log" 2>&1; then
    passed=$(grep -oP '^\d+(?= passed)' "$test_log" || echo "?")
    record_pass "$passed test(s) passed"
else
    record_fail "pytest suite failed"
    echo "--- last 15 lines of pytest output ---"
    tail -15 "$test_log"
fi

# ── Phase 3: GC doctor (temp-root, 16 GCD scenarios) ────────────────
start_phase "phase3" "Phase 3: GC doctor"

gc_log="$run_dir/gc-doctor.log"

if [ "$skip_gc" = true ]; then
    record_skip "--fast requested; GC doctor skipped"
elif [ ! -x "$SCRIPT_DIR/comfygo-gcd-harness.sh" ]; then
    record_fail "scripts/comfygo-gcd-harness.sh not found or not executable"
else
    if COMFYGO_GCD_EVIDENCE_DIR="$run_dir" "$SCRIPT_DIR/comfygo-gcd-harness.sh" 2>&1 | tee -a "$gc_log"; then
        increment_phase_count pass
    else
        failed=1
        increment_phase_count fail
    fi
fi

# ── Phase 4: Live validation (optional) ─────────────────────────────
start_phase "phase4" "Phase 4: Live validation"

if [ "$skip_live" = true ]; then
    record_skip "--fast requested; live validation skipped"
elif [ "$preflight_git_clean" != true ]; then
    record_skip "repo is not clean; live validation requires clean git state"
elif [ -n "${COMFYUI_DIR:-}" ] && [ -d "$COMFYUI_DIR" ]; then
    if [ -x "$SCRIPT_DIR/comfygo-live-validate" ]; then
        live_log="$run_dir/live-validate.log"
        if "$SCRIPT_DIR/comfygo-live-validate" > "$live_log" 2>&1; then
            record_pass "live validation succeeded"
        else
            record_fail "live validation failed"
            echo "--- last 15 lines of live validation ---"
            tail -15 "$live_log"
        fi
    else
        record_fail "scripts/comfygo-live-validate not found"
    fi
else
    record_skip "COMFYUI_DIR not set or missing"
fi

# ── Result ──────────────────────────────────────────────────────────
print_phase_summary
echo ""
if [ "$failed" -eq 0 ]; then
    echo "PASS: all verification passed"
    echo "Evidence: $run_dir"
    exit 0
else
    echo "FAIL: one or more checks failed"
    echo "Evidence: $run_dir"
    exit 1
fi
