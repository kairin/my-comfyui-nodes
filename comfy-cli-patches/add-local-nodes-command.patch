+import fnmatch
+import os
+import shutil
+import subprocess
+from pathlib import Path
+from typing import Annotated
+
+import typer
+from rich import print as rprint
+
+from comfy_cli import tracking
+from comfy_cli.workspace_manager import WorkspaceManager
+
+app = typer.Typer()
+workspace_manager = WorkspaceManager()
+
+DEFAULT_REPO = "~/Apps/my-comfyui-nodes"
+
+EXCLUDED_NAMES = {
+    ".git",
+    ".hg",
+    ".svn",
+    "__pycache__",
+    ".pytest_cache",
+    ".mypy_cache",
+    ".ruff_cache",
+    ".tracking",
+    ".env",
+    ".env.local",
+    "custom_models.json",
+    "debug_config.json",
+    "system_prompts_user.json",
+    "tests",
+    "testframework",
+}
+
+EXCLUDED_PATTERNS = [
+    "*.pyc",
+    "*.pyo",
+    "*.log",
+    "*.sqlite",
+    "*.db",
+    "*.token",
+    "*.safetensors",
+    "*.ckpt",
+    "*.pt",
+    "*.pth",
+    "*.bin",
+    "*.gguf",
+    "*.onnx",
+    "debug_*.json",
+    "tests/",
+    "testframework/",
+    "test*.py",
+    "pytest.ini",
+    "requirements-dev.txt",
+    "conftest.py",
+]
+
+
+def _resolve_repo(repo: str | Path | None) -> Path:
+    value = repo or os.environ.get("COMFY_LOCAL_NODES_REPO") or DEFAULT_REPO
+    return Path(value).expanduser().resolve()
+
+
+def _selected_workspace() -> Path:
+    if workspace_manager.workspace_path is None:
+        rprint("[bold red]ComfyUI workspace is not set.[/bold red]")
+        rprint("[dim]Use --workspace, --recent, --here, or set a default workspace.[/dim]")
+        raise typer.Exit(code=1)
+    return Path(workspace_manager.workspace_path).expanduser().resolve()
+
+
+def _is_excluded(name: str) -> bool:
+    if name in EXCLUDED_NAMES:
+        return True
+    return any(fnmatch.fnmatch(name, pattern) for pattern in EXCLUDED_PATTERNS)
+
+
+def _ignore(_directory: str, names: list[str]) -> set[str]:
+    return {name for name in names if _is_excluded(name)}
+
+
+def _copy_item(source: Path, destination: Path, dry_run: bool) -> None:
+    if dry_run:
+        rprint(f"[dim]would sync[/dim] {source} -> {destination}")
+        return
+
+    if source.is_dir():
+        destination.mkdir(parents=True, exist_ok=True)
+        shutil.copytree(source, destination, dirs_exist_ok=True, ignore=_ignore)
+    else:
+        destination.parent.mkdir(parents=True, exist_ok=True)
+        shutil.copy2(source, destination)
+
+
+def _apply_patch(workspace: Path, patch_path: Path, dry_run: bool) -> None:
+    check_cmd = ["git", "-C", str(workspace), "apply", "--check", str(patch_path)]
+    reverse_check_cmd = ["git", "-C", str(workspace), "apply", "--reverse", "--check", str(patch_path)]
+
+    if subprocess.run(check_cmd, check=False, capture_output=True).returncode == 0:
+        if dry_run:
+            rprint(f"[dim]would apply patch[/dim] {patch_path.name}")
+            return
+        subprocess.run(["git", "-C", str(workspace), "apply", str(patch_path)], check=True)
+        rprint(f"[green]Applied patch:[/green] {patch_path.name}")
+        return
+
+    if subprocess.run(reverse_check_cmd, check=False, capture_output=True).returncode == 0:
+        rprint(f"[yellow]Patch already applied:[/yellow] {patch_path.name}")
+        return
+
+    rprint(f"[bold red]Patch does not apply cleanly:[/bold red] {patch_path}")
+    raise typer.Exit(code=1)
+
+
+def _sync(repo_path: Path, workspace: Path, apply_patches: bool, dry_run: bool) -> None:
+    source_root = repo_path / "custom_nodes"
+    if not source_root.is_dir():
+        rprint(f"[bold red]Vendored custom_nodes directory not found:[/bold red] {source_root}")
+        raise typer.Exit(code=1)
+
+    destination_root = workspace / "custom_nodes"
+    if not dry_run:
+        destination_root.mkdir(parents=True, exist_ok=True)
+
+    for source in sorted(source_root.iterdir(), key=lambda p: p.name.lower()):
+        if _is_excluded(source.name):
+            continue
+        _copy_item(source, destination_root / source.name, dry_run=dry_run)
+
+    if apply_patches:
+        patches_dir = repo_path / "comfyui-patches"
+        for patch_path in sorted(patches_dir.glob("*.patch")) if patches_dir.is_dir() else []:
+            _apply_patch(workspace, patch_path, dry_run=dry_run)
+
+
+@app.command(help="Show the selected vendored-node repo and ComfyUI workspace.")
+@tracking.track_command("local-nodes")
+def status(
+    repo: Annotated[
+        str | None,
+        typer.Option("--repo", help="Vendored node repo. Defaults to COMFY_LOCAL_NODES_REPO or ~/Apps/my-comfyui-nodes."),
+    ] = None,
+):
+    repo_path = _resolve_repo(repo)
+    workspace = _selected_workspace()
+    rprint(f"Vendored node repo: [bold]{repo_path}[/bold]")
+    rprint(f"ComfyUI workspace: [bold]{workspace}[/bold]")
+    rprint(f"Vendored custom_nodes: {'yes' if (repo_path / 'custom_nodes').is_dir() else 'no'}")
+    rprint(f"ComfyUI custom_nodes: {'yes' if (workspace / 'custom_nodes').is_dir() else 'no'}")
+
+
+@app.command(help="Sync vendored custom nodes into the selected ComfyUI workspace.")
+@tracking.track_command("local-nodes")
+def sync(
+    repo: Annotated[
+        str | None,
+        typer.Option("--repo", help="Vendored node repo. Defaults to COMFY_LOCAL_NODES_REPO or ~/Apps/my-comfyui-nodes."),
+    ] = None,
+    apply_patches: Annotated[
+        bool,
+        typer.Option("--apply-patches/--no-patches", help="Apply repo/comfyui-patches/*.patch after syncing nodes."),
+    ] = True,
+    dry_run: Annotated[
+        bool,
+        typer.Option("--dry-run", help="Print actions without copying files or applying patches."),
+    ] = False,
+):
+    repo_path = _resolve_repo(repo)
+    workspace = _selected_workspace()
+    _sync(repo_path, workspace, apply_patches=apply_patches, dry_run=dry_run)
+    rprint("[bold green]Local nodes sync complete.[/bold green]")
+
+
+@app.command("apply-patches", help="Apply vendored ComfyUI core patches without syncing custom nodes.")
+@tracking.track_command("local-nodes")
+def apply_patches(
+    repo: Annotated[
+        str | None,
+        typer.Option("--repo", help="Vendored node repo. Defaults to COMFY_LOCAL_NODES_REPO or ~/Apps/my-comfyui-nodes."),
+    ] = None,
+    dry_run: Annotated[
+        bool,
+        typer.Option("--dry-run", help="Print actions without applying patches."),
+    ] = False,
+):
+    repo_path = _resolve_repo(repo)
+    workspace = _selected_workspace()
+    patches_dir = repo_path / "comfyui-patches"
+    if not patches_dir.is_dir():
+        rprint(f"[yellow]No patch directory found:[/yellow] {patches_dir}")
+        return
+    for patch_path in sorted(patches_dir.glob("*.patch")):
+        _apply_patch(workspace, patch_path, dry_run=dry_run)
+    rprint("[bold green]Patch application complete.[/bold green]")
