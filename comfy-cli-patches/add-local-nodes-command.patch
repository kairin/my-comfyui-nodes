@@ -0,0 +1,55 @@
+from pathlib import Path
+from unittest.mock import patch
+
+from comfy_cli.command import local_nodes
+
+
+def test_sync_copies_vendored_node_to_workspace(tmp_path):
+    repo = tmp_path / "repo"
+    workspace = tmp_path / "ComfyUI"
+    node = repo / "custom_nodes" / "ExampleNode"
+    node.mkdir(parents=True)
+    (node / "node.py").write_text("VALUE = 1\n", encoding="utf-8")
+    (node / "__pycache__").mkdir()
+    (node / "__pycache__" / "node.pyc").write_bytes(b"cache")
+
+    with patch.object(local_nodes.workspace_manager, "workspace_path", str(workspace)):
+        local_nodes.sync(repo=str(repo), apply_patches=False)
+
+    copied = workspace / "custom_nodes" / "ExampleNode" / "node.py"
+    assert copied.read_text(encoding="utf-8") == "VALUE = 1\n"
+    assert not (workspace / "custom_nodes" / "ExampleNode" / "__pycache__").exists()
+
+
+def test_apply_patch_skips_already_applied_patch(tmp_path):
+    repo = tmp_path / "repo"
+    workspace = tmp_path / "ComfyUI"
+    patches = repo / "comfyui-patches"
+    patches.mkdir(parents=True)
+    patch_path = patches / "already.patch"
+    patch_path.write_text("diff --git a/file b/file\n", encoding="utf-8")
+
+    def run_side_effect(cmd, check=False, capture_output=False):
+        class Result:
+            returncode = 1
+
+        class ReverseResult:
+            returncode = 0
+
+        if "--reverse" in cmd:
+            return ReverseResult()
+        return Result()
+
+    with (
+        patch.object(local_nodes.workspace_manager, "workspace_path", str(workspace)),
+        patch("comfy_cli.command.local_nodes.subprocess.run", side_effect=run_side_effect) as mock_run,
+    ):
+        local_nodes.apply_patches(repo=str(repo))
+
+    assert mock_run.call_count == 2
+
+
+def test_resolve_repo_prefers_environment(tmp_path, monkeypatch):
+    monkeypatch.setenv("COMFY_LOCAL_NODES_REPO", str(tmp_path))
+
+    assert local_nodes._resolve_repo(None) == Path(tmp_path).resolve()
