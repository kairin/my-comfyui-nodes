+def qwen_image_vae():
+    if AutoencoderKLQwenImage is None:
+        raise RuntimeError("Qwen Image VAE support requires diffusers with AutoencoderKLQwenImage.")
+
+    class ComfyAutoencoderKLQwenImage(AutoencoderKLQwenImage):
+        @property
+        def device(self):
+            return getattr(self, "_comfy_device", next(self.parameters()).device)
+
+        @device.setter
+        def device(self, value):
+            self._comfy_device = value
+
+        def encode(self, x):
+            return super().encode(x, return_dict=True).latent_dist.sample()
+
+        def decode(self, z, **kwargs):
+            return super().decode(z, return_dict=True).sample
+
+    return ComfyAutoencoderKLQwenImage()
